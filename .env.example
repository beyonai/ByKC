HOST=0.0.0.0
PORT=8000
SERVICE_NAME=by-qa-manager
# HOST_MACHINE is optional. In production, prefer setting it explicitly.
# When omitted, the service will try to detect a non-loopback local IPv4 and
# fall back to 127.0.0.1 if none is available.

# Redis service registry
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DATABASE=0

AGENT_DATA_PATH=agent_data

# Knowledge base storage
DB_HOST=10.10.168.204
DB_PORT=5432
DB_SCHEMA=byai
DB_USER=gaussdb
DB_PASS=Admin@123
MINIO_ENDPOINT=127.0.0.1:19000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
KB_MINIO_BUCKET=knowledge-base
KB_MINIO_MARKDOWN_BUCKET=knowledge-base-markdown
MINIO_SECURE=false

# Knowledge base embedding
# Optional: use a custom provider instead of the built-in env provider.
# Format: module:attribute. The attribute can be a provider class, factory, or instance.
BY_QA_MODEL_CONFIG_PROVIDER=
EMBEDDING_MODEL_NAME=bge-m3
EMBEDDING_BASE_URL=https://embedding.example.com
EMBEDDING_API_KEY=replace-me
EMBEDDING_DIMENSION=1024
EMBEDDING_DISTANCE_METRIC=cosine
EMBEDDING_BATCH_MAX_TEXTS=10

# Shared LLM / QA models
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-me
CLASSIFIER_MODEL=gpt-4o-mini
CLASSIFIER_TEMP=0.0
RETRIEVAL_MODEL=gpt-4o
RETRIEVAL_TEMP=0.0
GENERATOR_MODEL=gpt-4o
GENERATOR_TEMP=0.7
QUALITY_MODEL=gpt-4o
QUALITY_TEMP=0.0
DECOMPOSER_MODEL=gpt-4o-mini
DECOMPOSER_TEMP=0.0
DECOMPOSER_MAX_SUB_QUERIES=5
AGGREGATOR_MODEL=gpt-4o
AGGREGATOR_TEMP=0.7

# Instant QA runtime
CLASSIFIER_MAX_MODEL_LEN=128000
RETRIEVAL_MAX_MODEL_LEN=128000
GENERATOR_MAX_MODEL_LEN=128000
QUALITY_MAX_MODEL_LEN=128000
DECOMPOSER_MAX_MODEL_LEN=128000
AGGREGATOR_MAX_MODEL_LEN=128000
EMBEDDING_MAX_MODEL_LEN=128000
INSTANT_SEARCH_MAX_CONTEXT_RATIO=0.8
INSTANT_SEARCH_RESERVED_TOKENS=2000
INSTANT_SEARCH_MIN_SENTENCE_TOKENS=50

# QA persistence
CHECKPOINTER_SQLITE_PATH=./data/checkpoints.db

# Knowledge base cache tuning
KB_FETCH_CACHE_TTL_SECONDS=86400
KB_FETCH_CACHE_CLEANUP_INTERVAL_SECONDS=600
